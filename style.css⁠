/* Reset & Base styling */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Figtree', -apple-system, BlinkMacSystemFont, sans-serif;
    -webkit-tap-highlight-color: transparent;
}

body {
    background-color: #000000;
    color: #ffffff;
    display: flex;
    justify-content: center;
    min-height: 100vh;
    overflow: hidden;
}

.app-container {
    width: 100vw;
    height: 100vh;
    max-width: 480px;
    background-color: #000000;
    display: flex;
    flex-direction: column;
    position: relative;
    padding-bottom: env(safe-area-inset-bottom);
}

/* Header */
.header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 45px 16px 12px 16px;
    flex-shrink: 0;
}

.header-left {
    display: flex;
    align-items: center;
    gap: 12px;
}

.profile-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #282828;
}

.profile-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

h1 {
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.4px;
}

.add-btn {
    background: none;
    border: none;
    color: #ffffff;
    font-size: 26px;
    cursor: pointer;
    display: flex;
    align-items: center;
}

/* Scroll Area */
.content {
    padding: 8px 16px;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 16px;
    overflow-y: auto;
    position: relative;
}

.import-card {
    width: 100%;
    background-color: #121212;
    border: none;
    border-radius: 8px;
    padding: 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    color: #ffffff;
    cursor: pointer;
    transition: background-color 0.2s;
    flex-shrink: 0;
}

.import-card:active {
    background-color: #1a1a1a;
}

.import-left {
    display: flex;
    align-items: center;
    gap: 16px;
    flex: 1;
}

.import-icon {
    font-size: 20px;
    color: #ffffff;
    opacity: 0.9;
}

.import-text {
    font-size: 14px;
    font-weight: 700;
    line-height: 1.4;
    text-align: left;
}

.arrow-icon {
    color: #ffffff;
    opacity: 0.8;
    font-size: 14px;
}

/* 3D COVERFLOW PLATFORM CONTAINER */
.library-3d-viewport {
    width: 100%;
    height: 330px;
    background: #000000;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    border-radius: 12px;
}

.coverflow-container {
    position: relative;
    width: 100%;
    height: 220px;
    display: flex;
    align-items: center;
    justify-content: center;
    perspective: 1000px; /* Deepens the 3D depth field */
    perspective-origin: 50% 30%; /* Higher camera lens angle to view down at the side spines */
    transform-style: preserve-3d;
    cursor: grab;
}

/* THE 3D RECTANGULAR VINYL CASE HULL */
.album-3d-case {
    position: absolute;
    width: 150px;
    height: 150px;
    transform-style: preserve-3d;
    transition: transform 0.5s cubic-bezier(0.2, 0.85, 0.3, 1.05), opacity 0.4s ease;
    user-select: none;
    -webkit-box-reflect: below 18px linear-gradient(transparent, transparent 35%, rgba(255, 255, 255, 0.25));
}

.case-face {
    position: absolute;
    background-color: #181818;
    backface-visibility: visible;
    box-shadow: inset 0 0 20px rgba(0,0,0,0.85);
}

/* Front Artwork Face Plate */
.case-face.face-front {
    width: 150px;
    height: 150px;
    top: 0;
    left: 0;
    transform: rotateY(0deg) translateZ(12px); /* Offsets forward out of the box grid */
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 6px;
    overflow: hidden;
}

.case-face.face-front img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

/* Left Thickness Edge Spine Profile */
.case-face.face-left {
    width: 24px; /* Physical object thickness volume */
    height: 150px;
    top: 0;
    left: -12px;
    transform: rotateY(-90deg) translateZ(0);
    background: linear-gradient(to right, #0d0d0d, #2a2a2a);
    border: 1px solid rgba(255, 255, 255, 0.12);
    display: flex;
    align-items: center;
    justify-content: center;
}

/* Right Thickness Edge Spine Profile */
.case-face.face-right {
    width: 24px;
    height: 150px;
    top: 0;
    left: auto;
    right: -12px;
    transform: rotateY(90deg) translateZ(0);
    background: linear-gradient(to left, #0d0d0d, #2a2a2a);
    border: 1px solid rgba(255, 255, 255, 0.12);
    display: flex;
    align-items: center;
    justify-content: center;
}

/* Top Depth Face Lid */
.case-face.face-top {
    width: 150px;
    height: 24px;
    top: -12px;
    left: 0;
    transform: rotateX(90deg) translateZ(0);
    background: linear-gradient(to bottom, #333333, #121212);
    border: 1px solid rgba(255, 255, 255, 0.15);
}

/* Vertical text alignment on spine edge track */
.spine-text-vertical {
    font-size: 8px;
    font-weight: 800;
    color: rgba(255, 255, 255, 0.75);
    text-transform: uppercase;
    white-space: nowrap;
    letter-spacing: 2px;
    transform: rotate(90deg);
    width: 130px;
    text-align: center;
    overflow: hidden;
    text-overflow: ellipsis;
}

/* Active central track metadata layout values panel */
.center-track-title-display {
    position: absolute;
    bottom: 0px;
    width: 100%;
    text-align: center;
    pointer-events: none;
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding: 0 16px;
}

.center-main-title {
    font-size: 16px;
    font-weight: 700;
    color: #ffffff;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.center-sub-artist {
    font-size: 12px;
    font-weight: 500;
    color: #b3b3b3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

/* Tips Module Section UI */
.tips-card {
    background-color: #121212;
    border-radius: 8px;
    padding: 20px 16px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    flex-shrink: 0;
}

.tips-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    margin-bottom: 12px;
}

.tips-label {
    font-size: 11px;
    font-weight: 600;
    color: #a7a7a7;
}

.close-btn {
    background: none;
    border: none;
    color: #b3b3b3;
    font-size: 16px;
    cursor: pointer;
}

.tips-title {
    font-size: 15px;
    font-weight: 700;
    margin-bottom: 4px;
    letter-spacing: -0.1px;
}

.tips-subtitle {
    font-size: 13px;
    color: #b3b3b3;
    margin-bottom: 20px;
    font-weight: 500;
}

.action-btn {
    background-color: #ffffff;
    color: #000000;
    border: none;
    border-radius: 20px;
    padding: 10px 18px;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
}

/* Bottom Player Deck Row styling */
.bottom-section {
    position: absolute;
    bottom: 0;
    width: 100%;
    background-color: #000000;
    padding-bottom: 24px;
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
}

.mini-player {
    background-color: #51071e; 
    margin: 0 8px 16px 8px;
    border-radius: 8px;
    padding: 8px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: relative;
}

.player-left {
    display: flex;
    align-items: center;
    gap: 12px;
    flex: 1;
    min-width: 0;
}

.album-art {
    width: 38px;
    height: 38px;
    border-radius: 4px;
    overflow: hidden;
    flex-shrink: 0;
    background-color: #282828;
    display: flex;
    align-items: center;
    justify-content: center;
}

.album-art img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.song-info {
    display: flex;
    flex-direction: column;
    min-width: 0;
}

.song-title {
    font-size: 13px;
    font-weight: 600;
    color: #ffffff;
    margin-bottom: 1px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.song-artist {
    font-size: 12px;
    color: #b3b3b3;
    display: flex;
    align-items: center;
    gap: 4px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.local-badge {
    color: #1db954;
    font-size: 11px;
    display: flex;
    align-items: center;
}

.player-right {
    display: flex;
    align-items: center;
    gap: 20px;
    padding-right: 8px;
}

.device-btn, .play-btn {
    background: none;
    border: none;
    color: #ffffff;
    font-size: 18px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
}

.play-btn {
    font-size: 16px;
    width: 20px;
}

.progress-bar {
    position: absolute;
    bottom: 0;
    left: 8px;
    right: 8px;
    height: 2px;
    background-color: rgba(255, 255, 255, 0.12);
}

.progress-fill {
    width: 0%;
    height: 100%;
    background-color: #ffffff;
    transition: width 0.1s linear;
}

.bottom-nav {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
}

.nav-item {
    background: none;
    border: none;
    color: #ffffff;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    cursor: pointer;
}

.nav-icon {
    font-size: 20px;
    color: #ffffff;
}

.nav-item span {
    font-size: 10px;
    font-weight: 500;
    color: #ffffff;
}
