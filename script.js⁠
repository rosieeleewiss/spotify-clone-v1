document.addEventListener('DOMContentLoaded', () => {
    let libraryTracksList = [];
    let focusedIndex = 0;
    
    let logicDragActive = false;
    let startingTouchPointX = 0;
    let interactiveLiveDisplacementDeltaX = 0;

    // DOM Links setup mapping definitions
    const closeTips = document.getElementById('closeTips');
    const tipsCard = document.getElementById('tipsCard');
    const playBtn = document.getElementById('playBtn');
    const importBtn = document.getElementById('importBtn');
    const addBtnPlus = document.getElementById('addBtnPlus');
    const fileInput = document.getElementById('hiddenFileInput');
    const audioEngine = document.getElementById('audioEngine');
    const dropZoneViewport = document.getElementById('dropZoneViewport');
    const coverflowContainer = document.getElementById('coverflowContainer');
    
    const centerMainTitle = document.getElementById('centerMainTitle');
    const centerSubArtist = document.getElementById('centerSubArtist');

    const playerTitle = document.getElementById('playerTitle');
    const playerArtist = document.getElementById('playerArtist');
    const progressFill = document.getElementById('progressFill');
    const playerAlbumArtContainer = document.getElementById('playerAlbumArtContainer');

    if (closeTips && tipsCard) {
        closeTips.addEventListener('click', () => tipsCard.style.display = 'none');
    }

    // HIGH FIDELITY 3D CORE ROTATING MATH TRANSFORMATIONS COMPUTATION ENGINE
    function computeGeometries3DTransforms() {
        if (libraryTracksList.length === 0) return;

        const structuralBoxes = coverflowContainer.querySelectorAll('.album-3d-case');
        
        structuralBoxes.forEach((boxHull, idx) => {
            const structuralOffset = idx - focusedIndex;
            
            let translateX = 0;
            let rotateY = 0;
            let translateZ = 0;
            let compositeOpacity = 1;
            let spatialIndexLayer = 100 - Math.abs(structuralOffset);

            if (structuralOffset === 0) {
                // Focus Center card matrix mapping
                translateX = 0;
                rotateY = 0;
                translateZ = 140; 
                spatialIndexLayer = 700;
                compositeOpacity = 1;
            } else if (structuralOffset < 0) {
                // Left Wing side cards configuration setup parameters
                rotateY = 65; 
                translateX = (structuralOffset * 55) - 85; 
                translateZ = -20; 
                compositeOpacity = Math.max(0.2, 1 + (structuralOffset * 0.3));
            } else if (structuralOffset > 0) {
                // Right Wing side cards configuration setup parameters
                rotateY = -65;
                translateX = (structuralOffset * 55) + 85;
                translateZ = -20;
                compositeOpacity = Math.max(0.2, 1 - (structuralOffset * 0.3));
            }

            if (Math.abs(structuralOffset) > 2) {
                compositeOpacity = 0;
            }

            boxHull.style.transform = `translateX(${translateX}px) rotateY(${rotateY}deg) translateZ(${translateZ}px)`;
            boxHull.style.zIndex = spatialIndexLayer;
            boxHull.style.opacity = compositeOpacity;
        });
    }

    function triggerFocusedTrackReorientation(targetIndexKey) {
        if (libraryTracksList.length === 0) return;
        
        focusedIndex = Math.max(0, Math.min(targetIndexKey, libraryTracksList.length - 1));
        computeGeometries3DTransforms();

        const track = libraryTracksList[focusedIndex];
        
        // Render current selected track string metadata
        centerMainTitle.textContent = track.title;
        centerSubArtist.textContent = track.artist;

        playerTitle.textContent = track.title;
        playerArtist.textContent = track.artist;
        playerAlbumArtContainer.innerHTML = `<img src="${track.coverImageURL}" style="width:100%; height:100%; object-fit:cover;">`;

        if (track.blobResourceObjectLink) {
            audioEngine.src = track.blobResourceObjectLink;
            audioEngine.play().catch(() => {});
        }
    }

    // BUILDS MULTI-FACED RECTANGULAR GEOMETRIC BOX NODE WITH SIDE TEXT
    function appendTrackTo3DCarousel(title, artist, coverURL, blobLink = null) {
        const systemTrackDataNode = {
            title: title,
            artist: artist,
            coverImageURL: coverURL,
            blobResourceObjectLink: blobLink
        };

        libraryTracksList.push(systemTrackDataNode);

        const multiFaceBoxHullNode = document.createElement('div');
        multiFaceBoxHullNode.className = 'album-3d-case';
        
        multiFaceBoxHullNode.innerHTML = `
            <div class="case-face face-left">
                <div class="spine-text-vertical">${title}</div>
            </div>
            <div class="case-face face-top"></div>
            <div class="case-face face-front">
                <img src="${coverURL}">
            </div>
            <div class="case-face face-right">
                <div class="spine-text-vertical">${title}</div>
            </div>
        `;

        const localIndexScopeReferenceKey = libraryTracksList.length - 1;
        multiFaceBoxHullNode.addEventListener('click', () => {
            triggerFocusedTrackReorientation(localIndexScopeReferenceKey);
        });

        coverflowContainer.appendChild(multiFaceBoxHullNode);
    }

    function processIncomingAudioFiles(fileCollectionArray) {
        for (let i = 0; i < fileCollectionArray.length; i++) {
            const file = fileCollectionArray[i];
            if (!file.type.startsWith('audio/')) continue;

            let rawName = file.name.replace(/\.[^/.]+$/, "");
            let mappedTitle = rawName;
            let mappedArtist = "Yerel Parça";

            if (rawName.includes(" - ")) {
                const parts = rawName.split(" - ");
                mappedArtist = parts[0].trim();
                mappedTitle = parts[1].trim();
            }

            // Beautiful placeholder color dynamic gradient generator fallback if artwork tags aren't indexed
            const placeholderArtworkGradientUrl = `https://images.unsplash.com/photo-1614613535308-eb5fbd3d2c17?q=80&w=200&auto=format&fit=crop`;
            
            appendTrackTo3DCarousel(mappedTitle, mappedArtist, placeholderArtworkGradientUrl, URL.createObjectURL(file));
        }
        
        // Jump viewport focus tracking directly onto the newly parsed audio track item entry node index
        triggerFocusedTrackReorientation(libraryTracksList.length - fileCollectionArray.length);
    }

    // PRE-POPULATE PREMIUM STARTER MUSIC EXAMPLES DIRECTLY ON BOOT LOAD CYCLE
    appendTrackTo3DCarousel("Carita de Angel", "Maria Daniela Y Su Sonido Lasser", "https://images.unsplash.com/photo-1514525253161-7a46d19cd819?q=80&w=250&auto=format&fit=crop");
    appendTrackTo3DCarousel("After Hours", "The Weeknd", "https://images.unsplash.com/photo-1614613535308-eb5fbd3d2c17?q=80&w=250&auto=format&fit=crop");
    appendTrackTo3DCarousel("Future Nostalgia", "Dua Lipa", "https://images.unsplash.com/photo-1498038432885-c6f3f1b912ee?q=80&w=250&auto=format&fit=crop");

    // Initialize display state loop immediately
    triggerFocusedTrackReorientation(0);

    // High Precision Touch Inertia Gesture Trackers
    dropZoneViewport.addEventListener('touchstart', (e) => {
        logicDragActive = true;
        startingTouchPointX = e.touches[0].clientX;
        interactiveLiveDisplacementDeltaX = startingTouchPointX;
    }, { passive: true });

    dropZoneViewport.addEventListener('touchmove', (e) => {
        if (!logicDragActive || libraryTracksList.length === 0) return;
        const touchLiveCurrentCoordinateX = e.touches[0].clientX;
        const dynamicMotionDeltaDisplacement = touchLiveCurrentCoordinateX - interactiveLiveDisplacementDeltaX;
        
        if (Math.abs(dynamicMotionDeltaDisplacement) > 40) {
            if (dynamicMotionDeltaDisplacement > 0 && focusedIndex > 0) {
                triggerFocusedTrackReorientation(focusedIndex - 1);
                logicDragActive = false; 
            } else if (dynamicMotionDeltaDisplacement < 0 && focusedIndex < libraryTracksList.length - 1) {
                triggerFocusedTrackReorientation(focusedIndex + 1);
                logicDragActive = false;
            }
            interactiveLiveDisplacementDeltaX = touchLiveCurrentCoordinateX;
        }
    }, { passive: true });

    window.addEventListener('touchend', () => logicDragActive = false);

    // Import click triggers links bindings
    if (importBtn) importBtn.addEventListener('click', () => fileInput.click());
    if (addBtnPlus) addBtnPlus.addEventListener('click', () => fileInput.click());
    
    if (fileInput) {
        fileInput.addEventListener('change', (e) => {
            if (e.target.files.length > 0) processIncomingAudioFiles(e.target.files);
        });
    }

    // Media Control Action Listeners
    if (playBtn && audioEngine) {
        playBtn.addEventListener('click', () => {
            if (!audioEngine.src) return;
            if (audioEngine.paused) {
                audioEngine.play();
            } else {
                audioEngine.pause();
            }
        });

        audioEngine.addEventListener('play', () => { playBtn.innerHTML = '<i class="fa-solid fa-pause"></i>'; });
        audioEngine.addEventListener('pause', () => { playBtn.innerHTML = '<i class="fa-solid fa-play"></i>'; });
        audioEngine.addEventListener('timeupdate', () => {
            if (audioEngine.duration) {
                progressFill.style.width = `${(audioEngine.currentTime / audioEngine.duration) * 100}%`;
            }
        });
    }

    window.addEventListener('resize', computeGeometries3DTransforms);
});
