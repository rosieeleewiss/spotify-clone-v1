document.addEventListener('DOMContentLoaded', () => {
    // --- CORE ENGINE REGISTERS ---
    let libraryTracksList = [];
    let playlistRegistryCollection = [];
    let currentlySelectedPlaylistId = null;
    let focusedIndex = 0;
    
    let trackingMotionActive = false;
    let initialTouchX = 0;
    let slidingReferenceDeltaX = 0;
    
    let customUploadedCoverBase64 = null;
    let temporaryEditorContributorsList = [];

    // --- DOM ELEMENT BINDINGS ---
    const closeTips = document.getElementById('closeTips');
    const tipsCard = document.getElementById('tipsCard');
    const playBtn = document.getElementById('playBtn');
    const importBtn = document.getElementById('importBtn');
    const addBtnPlus = document.getElementById('addBtnPlus');
    const fileInput = document.getElementById('hiddenFileInput');
    const coverFileInput = document.getElementById('playlistCoverFileInput');
    const audioEngine = document.getElementById('audioEngine');
    const dropZoneViewport = document.getElementById('dropZoneViewport');
    const coverflowContainer = document.getElementById('coverflowContainer');
    const emptyNotice = document.getElementById('emptyNotice');
    
    const centerTrackTitleDisplay = document.getElementById('centerTrackTitleDisplay');
    const centerMainTitle = document.getElementById('centerMainTitle');
    const centerSubArtist = document.getElementById('centerSubArtist');

    const playerTitle = document.getElementById('playerTitle');
    const playerArtist = document.getElementById('playerArtist');
    const progressFill = document.getElementById('progressFill');
    const playerAlbumArtContainer = document.getElementById('playerAlbumArtContainer');

    const menuSheetOverlay = document.getElementById('menuSheetOverlay');
    const bottomSheet = document.getElementById('bottomSheet');
    const dragHandleContainer = document.getElementById('dragHandleContainer');

    const createPlaylistTriggerBtn = document.getElementById('createPlaylistTriggerBtn');
    const sheetMenuCreatePlaylistBtn = document.getElementById('sheetMenuCreatePlaylistBtn');
    const playlistModalOverlay = document.getElementById('playlistModalOverlay');
    const playlistNameInput = document.getElementById('playlistNameInput');
    const modalCancelBtn = document.getElementById('modalCancelBtn');
    const modalCreateBtn = document.getElementById('modalCreateBtn');
    const playlistsTargetBox = document.getElementById('playlistsTargetBox');
    
    const detailPanelView = document.getElementById('detailPanelView');
    const detailBackBtn = document.getElementById('detailBackBtn');
    const detailHeroTitle = document.getElementById('detailHeroTitle');
    const detailTracksListContainer = document.getElementById('detailTracksListContainer');
    const detailPlaylistCoverContainer = document.getElementById('detailPlaylistCoverContainer');
    const detailPanelDegistirBtn = document.getElementById('detailPanelDegistirBtn');
    const detailContributorsStrip = document.getElementById('detailContributorsStrip');

    const editorPanelView = document.getElementById('editorPanelView');
    const editorCancelBtn = document.getElementById('editorCancelBtn');
    const editorSaveBtn = document.getElementById('editorSaveBtn');
    const editorArtworkShowcase = document.getElementById('editorArtworkShowcase');
    const editorFallbackIcon = document.getElementById('editorFallbackIcon');
    const editorImagePreview = document.getElementById('editorImagePreview');
    const editorTitleInput = document.getElementById('editorTitleInput');
    const editorContributorsGrid = document.getElementById('editorContributorsGrid');
    const editorDeletePlaylistBtn = document.getElementById('editorDeletePlaylistBtn');

    const dynamicCaseGradients = [
        'linear-gradient(135deg, #ff0055 0%, #7a0026 100%)',
        'linear-gradient(135deg, #00c6ff 0%, #0072ff 100%)',
        'linear-gradient(135deg, #f9d423 0%, #ff4e50 100%)',
        'linear-gradient(135deg, #b31217 0%, #e52d27 100%)',
        'linear-gradient(135deg, #00f260 0%, #0575e6 100%)',
        'linear-gradient(135deg, #8a2387 0%, #e94057 100%)'
    ];

    // --- HIGH-CAPACITY STORAGE ENGINE (INDEXEDDB) ---
    let dbInstance = null;
    const DB_NAME = "MusicAppStorageEngine";
    const DB_VERSION = 1;

    function initDatabaseEngine(callback) {
        const request = indexedDB.open(DB_NAME, DB_VERSION);

        request.onupgradeneeded = (event) => {
            const db = event.target.result;
            if (!db.objectStoreNames.contains('tracks')) {
                db.createObjectStore('tracks', { keyPath: 'id', autoIncrement: true });
            }
            if (!db.objectStoreNames.contains('playlists')) {
                db.createObjectStore('playlists', { keyPath: 'id' });
            }
        };

        request.onsuccess = (event) => {
            dbInstance = event.target.result;
            if (callback) callback();
        };

        request.onerror = (event) => {
            console.error("Database connection failed:", event.target.error);
        };
    }

    function saveTrackToDatabase(trackObj, callback) {
        if (!dbInstance) return;
        const transaction = dbInstance.transaction(['tracks'], 'readwrite');
        const store = transaction.objectStore(['tracks']);
        const request = store.add(trackObj);

        request.onsuccess = () => {
            if (callback) callback();
        };
    }

    function saveAllPlaylistsToDatabase() {
        if (!dbInstance) return;
        const transaction = dbInstance.transaction(['playlists'], 'readwrite');
        const store = transaction.objectStore(['playlists']);
        
        // Clear old playlist entries before restructuring update
        store.clear().onsuccess = () => {
            playlistRegistryCollection.forEach(pl => {
                store.put(pl);
            });
        };
    }

    function loadAllDataFromDatabase() {
        if (!dbInstance) return;

        // 1. Recover Audio Tracks Store
        const trackTx = dbInstance.transaction(['tracks'], 'readonly');
        const trackStore = trackTx.objectStore('tracks');
        const getAllTracks = trackStore.getAll();

        getAllTracks.onsuccess = () => {
            libraryTracksList = getAllTracks.result || [];
            if (coverflowContainer) coverflowContainer.innerHTML = '';
            
            libraryTracksList.forEach((track, idx) => {
                build3DTrackDOMCard(track, idx);
            });

            if (libraryTracksList.length > 0) {
                if (tipsCard) tipsCard.style.display = 'none';
                triggerFocusedTrackReorientation(0, false); // Boot without auto-playing audio immediately
            } else {
                compute3DCaseSpaceTransforms();
            }
        };

        // 2. Recover Playlists Store
        const playlistTx = dbInstance.transaction(['playlists'], 'readonly');
        const playlistStore = playlistTx.objectStore('playlists');
        const getAllPlaylists = playlistStore.getAll();

        getAllPlaylists.onsuccess = () => {
            playlistRegistryCollection = getAllPlaylists.result || [];
            renderPlaylistsToDashboard();
        };
    }

    function deletePlaylistFromDatabase(id) {
        if (!dbInstance) return;
        const transaction = dbInstance.transaction(['playlists'], 'readwrite');
        const store = transaction.objectStore(['playlists']);
        store.delete(id);
    }

    // --- ONBOARDING TIPS LOGIC ---
    if (closeTips && tipsCard) {
        closeTips.addEventListener('click', () => {
            tipsCard.style.display = 'none';
        });
    }

    // --- BOTTOM SHEET GESTURE ENGINE LAYOUT ---
    let isDraggingSheet = false;
    let startY = 0;
    let currentY = 0;

    function closeSheetWithAnimation() {
        if (!bottomSheet) return;
        bottomSheet.classList.remove('dragging');
        bottomSheet.style.transform = '';
        if (menuSheetOverlay) menuSheetOverlay.classList.remove('active');
    }

    function resetSheetPosition() {
        if (!bottomSheet) return;
        bottomSheet.classList.remove('dragging');
        bottomSheet.style.transform = 'translateY(0)';
    }

    if (addBtnPlus && menuSheetOverlay) {
        addBtnPlus.addEventListener('click', (e) => {
            e.stopPropagation();
            bottomSheet.style.transform = '';
            menuSheetOverlay.classList.add('active');
        });

        menuSheetOverlay.addEventListener('click', (e) => {
            if (e.target === menuSheetOverlay) closeSheetWithAnimation();
        });
    }

    if (dragHandleContainer && bottomSheet) {
        dragHandleContainer.addEventListener('touchstart', (e) => {
            isDraggingSheet = true;
            startY = e.touches[0].clientY;
            bottomSheet.classList.add('dragging');
        }, { passive: true });

        window.addEventListener('touchmove', (e) => {
            if (!isDraggingSheet) return;
            currentY = e.touches[0].clientY;
            let deltaY = currentY - startY;
            if (deltaY > 0) bottomSheet.style.transform = `translateY(${deltaY}px)`;
        }, { passive: true });

        window.addEventListener('touchend', () => {
            if (!isDraggingSheet) return;
            isDraggingSheet = false;
            if ((currentY - startY) > 100) {
                closeSheetWithAnimation();
            } else {
                resetSheetPosition();
            }
        });
    }

    // --- PLAYLIST DATA MUTATION CONTROLS ---
    function openPlaylistNamingModal() {
        closeSheetWithAnimation();
        if (playlistNameInput) {
            playlistNameInput.value = '';
            playlistModalOverlay.classList.add('active');
            setTimeout(() => playlistNameInput.focus(), 150);
        }
    }

    if (createPlaylistTriggerBtn) createPlaylistTriggerBtn.addEventListener('click', openPlaylistNamingModal);
    if (sheetMenuCreatePlaylistBtn) sheetMenuCreatePlaylistBtn.addEventListener('click', openPlaylistNamingModal);

    if (modalCancelBtn) {
        modalCancelBtn.addEventListener('click', () => {
            playlistModalOverlay.classList.remove('active');
        });
    }

    if (modalCreateBtn) {
        modalCreateBtn.addEventListener('click', () => {
            let chosenName = playlistNameInput.value.trim();
            if (!chosenName) chosenName = "Çalma Listem";

            if (tipsCard) tipsCard.style.display = 'none';

            const playlistGradients = [
                'linear-gradient(135deg, #4568dc 0%, #b06ab3 100%)',
                'linear-gradient(135deg, #3a1c1c 0%, #5d4037 100%)',
                'linear-gradient(135deg, #1f4037 0%, #99f2c8 100%)',
                'linear-gradient(135deg, #2c3e50 0%, #bdc3c7 100%)'
            ];
            const randomBg = playlistGradients[Math.floor(Math.random() * playlistGradients.length)];
            const generatedId = 'pl_' + Date.now();

            const newPlaylistObj = {
                id: generatedId,
                name: chosenName,
                background: randomBg,
                coverImage: null,
                contributors: []
            };

            playlistRegistryCollection.push(newPlaylistObj);
            saveAllPlaylistsToDatabase();
            renderPlaylistsToDashboard();
            
            playlistModalOverlay.classList.remove('active');
            launchPlaylistDetailsView(generatedId);
        });
    }

    function renderPlaylistsToDashboard() {
        if (!playlistsTargetBox) return;
        playlistsTargetBox.innerHTML = '';

        playlistRegistryCollection.forEach(pl => {
            const playlistRowElement = document.createElement('div');
            playlistRowElement.className = 'playlist-row-item';

            let artContentHtml = `<i class="fa-solid fa-music"></i>`;
            if (pl.coverImage) {
                artContentHtml = `<img src="${pl.coverImage}" alt="Playlist Cover">`;
            }

            playlistRowElement.innerHTML = `
                <div class="playlist-art-square" style="${pl.coverImage ? '' : 'background: ' + pl.background}">
                    ${artContentHtml}
                </div>
                <div class="playlist-metadata">
                    <div class="playlist-name-label">${pl.name}</div>
                    <div class="playlist-desc-subtext">Çalma listesi • Kitaplığın</div>
                </div>
            `;

            playlistRowElement.addEventListener('click', () => {
                launchPlaylistDetailsView(pl.id);
            });

            playlistsTargetBox.appendChild(playlistRowElement);
        });
    }

    function launchPlaylistDetailsView(id) {
        const pl = playlistRegistryCollection.find(p => p.id === id);
        if (!pl) return;

        currentlySelectedPlaylistId = id;
        if (detailHeroTitle) detailHeroTitle.textContent = pl.name;

        if (detailPlaylistCoverContainer) {
            if (pl.coverImage) {
                detailPlaylistCoverContainer.style.background = 'none';
                detailPlaylistCoverContainer.innerHTML = `<img src="${pl.coverImage}" alt="Cover">`;
            } else {
                detailPlaylistCoverContainer.style.background = pl.background;
                detailPlaylistCoverContainer.innerHTML = `<i class="fa-solid fa-music"></i>`;
            }
        }

        if (detailContributorsStrip) {
            detailContributorsStrip.innerHTML = '';
            pl.contributors.forEach(url => {
                const img = document.createElement('img');
                img.className = 'contributor-mini-node';
                img.src = url;
                detailContributorsStrip.appendChild(img);
            });
        }

        renderDetailTracks();

        if (detailPanelView) detailPanelView.classList.add('active');
    }

    function renderDetailTracks() {
        if (!detailTracksListContainer) return;
        detailTracksListContainer.innerHTML = '';

        if (libraryTracksList.length === 0) {
            detailTracksListContainer.innerHTML = `
                <div class="empty-track-placeholder-state">
                    Bu çalma listesinde henüz şarkı yok. Şarkı yüklemek için yukarıdaki "içe aktar" düğmesini kullanabilirsiniz.
                </div>`;
        } else {
            libraryTracksList.forEach((track, index) => {
                const trElement = document.createElement('div');
                trElement.className = 'playlist-row-item';

                trElement.innerHTML = `
                    <div class="playlist-art-square" style="width:44px; height:44px; font-size:14px; background:${track.caseBackdropTone}">
                        <i class="fa-solid fa-play"></i>
                    </div>
                    <div class="playlist-metadata">
                        <div class="playlist-name-label" style="font-size:14px;">${track.title}</div>
                        <div class="playlist-desc-subtext" style="font-size:12px;">${track.artist}</div>
                    </div>
                `;

                trElement.addEventListener('click', (e) => {
                    e.stopPropagation();
                    triggerFocusedTrackReorientation(index, true);
                });
                detailTracksListContainer.appendChild(trElement);
            });
        }
    }

    if (detailBackBtn) {
        detailBackBtn.addEventListener('click', () => {
            detailPanelView.classList.remove('active');
            currentlySelectedPlaylistId = null;
        });
    }

    // --- MANAGEMENT WORKFLOW CONFIGURATION FOR EDIT VIEW ---
    if (detailPanelDegistirBtn) {
        detailPanelDegistirBtn.addEventListener('click', () => {
            const pl = playlistRegistryCollection.find(p => p.id === currentlySelectedPlaylistId);
            if (!pl) return;

            if (editorTitleInput) editorTitleInput.value = pl.name;
            customUploadedCoverBase64 = pl.coverImage;
            temporaryEditorContributorsList = [...pl.contributors];

            updateEditorArtPreviewState(pl);
            renderEditorContributorsGrid();

            if (editorPanelView) editorPanelView.classList.add('active');
        });
    }

    function updateEditorArtPreviewState(playlistObj) {
        if (!editorImagePreview || !editorFallbackIcon) return;
        if (customUploadedCoverBase64) {
            editorFallbackIcon.style.display = 'none';
            editorImagePreview.src = customUploadedCoverBase64;
            editorImagePreview.style.display = 'block';
        } else {
            editorImagePreview.style.display = 'none';
            editorFallbackIcon.style.display = 'block';
            if (editorArtworkShowcase) editorArtworkShowcase.style.background = playlistObj.background;
        }
    }

    if (editorArtworkShowcase && coverFileInput) {
        editorArtworkShowcase.addEventListener('click', () => coverFileInput.click());
    }

    if (coverFileInput) {
        coverFileInput.addEventListener('change', (e) => {
            const uploadedFile = e.target.files[0];
            if (uploadedFile && uploadedFile.type.startsWith('image/')) {
                const imgReader = new FileReader();
                imgReader.onload = (event) => {
                    customUploadedCoverBase64 = event.target.result;
                    if (editorImagePreview && editorFallbackIcon) {
                        editorFallbackIcon.style.display = 'none';
                        editorImagePreview.src = customUploadedCoverBase64;
                        editorImagePreview.style.display = 'block';
                    }
                };
                imgReader.readAsDataURL(uploadedFile);
            }
        });
    }

    function renderEditorContributorsGrid() {
        if (!editorContributorsGrid) return;
        editorContributorsGrid.innerHTML = '';

        const sampleAvatars = [
            'https://images.unsplash.com/photo-1534528741775-53994a69daeb?q=80&w=100&auto=format&fit=crop',
            'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?q=80&w=100&auto=format&fit=crop',
            'https://images.unsplash.com/photo-1494790108377-be9c29b29330?q=80&w=100&auto=format&fit=crop',
            'https://images.unsplash.com/photo-1500648767791-00dcc994a43e?q=80&w=100&auto=format&fit=crop'
        ];

        sampleAvatars.forEach((url, i) => {
            const item = document.createElement('div');
            item.className = 'editor-contributor-item';
            
            const isAdded = temporaryEditorContributorsList.includes(url);
            item.innerHTML = `
                <img src="${url}" class="editor-mini-avatar" alt="User">
                <span class="editor-user-name">Katılımcı ${i + 1}</span>
                <button class="toggle-user-add-btn ${isAdded ? 'added' : ''}">
                    <i class="fa-solid ${isAdded ? 'fa-minus' : 'fa-plus'}"></i>
                </button>
            `;

            const actionBtn = item.querySelector('.toggle-user-add-btn');
            actionBtn.addEventListener('click', () => {
                if (temporaryEditorContributorsList.includes(url)) {
                    temporaryEditorContributorsList = temporaryEditorContributorsList.filter(u => u !== url);
                    actionBtn.classList.remove('added');
                    actionBtn.innerHTML = '<i class="fa-solid fa-plus"></i>';
                } else {
                    temporaryEditorContributorsList.push(url);
                    actionBtn.classList.add('added');
                    actionBtn.innerHTML = '<i class="fa-solid fa-minus"></i>';
                }
            });

            editorContributorsGrid.appendChild(item);
        });
    }

    if (editorSaveBtn) {
        editorSaveBtn.addEventListener('click', () => {
            const pl = playlistRegistryCollection.find(p => p.id === currentlySelectedPlaylistId);
            if (pl) {
                const finalTitle = editorTitleInput.value.trim();
                if (finalTitle) pl.name = finalTitle;
                pl.coverImage = customUploadedCoverBase64;
                pl.contributors = [...temporaryEditorContributorsList];

                saveAllPlaylistsToDatabase();
                launchPlaylistDetailsView(pl.id);
                renderPlaylistsToDashboard();
            }
            if (editorPanelView) editorPanelView.classList.remove('active');
        });
    }

    if (editorCancelBtn) {
        editorCancelBtn.addEventListener('click', () => {
            if (editorPanelView) editorPanelView.classList.remove('active');
        });
    }

    if (editorDeletePlaylistBtn) {
        editorDeletePlaylistBtn.addEventListener('click', () => {
            deletePlaylistFromDatabase(currentlySelectedPlaylistId);
            playlistRegistryCollection = playlistRegistryCollection.filter(p => p.id !== currentlySelectedPlaylistId);
            renderPlaylistsToDashboard();

            if (editorPanelView) editorPanelView.classList.remove('active');
            if (detailPanelView) detailPanelView.classList.remove('active');
            currentlySelectedPlaylistId = null;
        });
    }

    // --- INTERACTIVE COVERFLOW 3D ENGINE CONTROLLER ---
    function compute3DCaseSpaceTransforms() {
        if (!emptyNotice || !centerTrackTitleDisplay || !coverflowContainer) return;

        if (libraryTracksList.length === 0) {
            emptyNotice.style.display = 'flex';
            centerTrackTitleDisplay.style.display = 'none';
            return;
        }
        emptyNotice.style.display = 'none';
        centerTrackTitleDisplay.style.display = 'flex';

        const structuralCases = coverflowContainer.querySelectorAll('.album-3d-case');
        
        structuralCases.forEach((albumCase, idx) => {
            const trackingOffset = idx - focusedIndex;
            
            let translateX = 0;
            let rotateY = 0;
            let translateZ = 0;
            let opacityValue = 1;
            let layeredZIndex = 100 - Math.abs(trackingOffset);

            if (trackingOffset === 0) {
                translateX = 0;
                rotateY = 0;
                translateZ = 130;
                layeredZIndex = 600;
                opacityValue = 1;
            } else if (trackingOffset < 0) {
                rotateY = 65; 
                translateX = (trackingOffset * 45) - 80; 
                translateZ = -40; 
                opacityValue = Math.max(0.15, 1 + (trackingOffset * 0.25));
            } else if (trackingOffset > 0) {
                rotateY = -65;
                translateX = (trackingOffset * 45) + 80;
                translateZ = -40;
                opacityValue = Math.max(0.15, 1 - (trackingOffset * 0.25));
            }

            if (Math.abs(trackingOffset) > 3) opacityValue = 0;

            albumCase.style.transform = `translateX(${translateX}px) rotateY(${rotateY}deg) translateZ(${translateZ}px)`;
            albumCase.style.zIndex = layeredZIndex;
            albumCase.style.opacity = opacityValue;
        });
    }

    function triggerFocusedTrackReorientation(targetIdx, autoPlayTrack = true) {
        if (libraryTracksList.length === 0) return;
        focusedIndex = Math.max(0, Math.min(targetIdx, libraryTracksList.length - 1));
        compute3DCaseSpaceTransforms();

        const isolatedTrackNode = libraryTracksList[focusedIndex];
        
        if (centerMainTitle) centerMainTitle.textContent = isolatedTrackNode.title;
        if (centerSubArtist) centerSubArtist.textContent = isolatedTrackNode.artist;
        if (playerTitle) playerTitle.textContent = isolatedTrackNode.title;
        if (playerArtist) playerArtist.textContent = isolatedTrackNode.artist;
        
        if (playerAlbumArtContainer) {
            playerAlbumArtContainer.style.background = isolatedTrackNode.caseBackdropTone;
            playerAlbumArtContainer.innerHTML = `<i class="fa-solid fa-compact-disc fa-spin" style="color: rgba(255,255,255,0.8); font-size:15px;"></i>`;
        }
        
        if (audioEngine && isolatedTrackNode.audioRawBase64) {
            audioEngine.src = isolatedTrackNode.audioRawBase64;
            if (autoPlayTrack) {
                audioEngine.play().catch(() => {});
            }
        }
    }

    function build3DTrackDOMCard(trackObj, index) {
        const physicalCaseNode = document.createElement('div');
        physicalCaseNode.className = 'album-3d-case';
        
        physicalCaseNode.innerHTML = `
            <div class="case-face face-left">
                <div class="spine-text-vertical">${trackObj.title}</div>
            </div>
            <div class="case-face face-front" style="background: ${trackObj.caseBackdropTone}">
                 <i class="fa-solid fa-record-vinyl"></i>
            </div>
            <div class="case-face face-right">
                <div class="spine-text-vertical">${trackObj.title}</div>
            </div>
        `;
        
        physicalCaseNode.addEventListener('click', () => {
            if (focusedIndex !== index) {
                triggerFocusedTrackReorientation(index, true);
            }
        });
        if (coverflowContainer) coverflowContainer.appendChild(physicalCaseNode);
    }

    // --- HIGH-PERFORMANCE SEQUENTIAL FILE INGESTION ---
    function processSelectedFilesInputPackets(filesList) {
        let checkInitialLibraryBootState = (libraryTracksList.length === 0);
        let currentFileIndex = 0;

        function readNextFile() {
            if (currentFileIndex >= filesList.length) return;

            const musicFile = filesList[currentFileIndex];
            const lowercasedName = musicFile.name.toLowerCase();

            // Support both MP3 media protocols and ORG asset uploads
            if (!musicFile.type.startsWith('audio/') && !lowercasedName.endsWith('.org') && !lowercasedName.endsWith('.mp3')) {
                currentFileIndex++;
                readNextFile();
                return;
            }

            let rawCleanedString = musicFile.name.replace(/\.[^/.]+$/, "");
            let derivedTitleString = rawCleanedString;
            let derivedArtistString = "Yerel Parça";

            if (rawCleanedString.includes(" - ")) {
                const wordSplitFragments = rawCleanedString.split(" - ");
                derivedArtistString = wordSplitFragments[0].trim();
                derivedTitleString = wordSplitFragments[1].trim();
            }

            const dynamicGradIndex = libraryTracksList.length % dynamicCaseGradients.length;
            const choiceBackdropTone = dynamicCaseGradients[dynamicGradIndex];

            const dataReader = new FileReader();
            dataReader.onload = (event) => {
                const base64AudioData = event.target.result;

                const systemTrackPayload = {
                    title: derivedTitleString,
                    artist: derivedArtistString,
                    audioRawBase64: base64AudioData,
                    caseBackdropTone: choiceBackdropTone
                };

                // Save onto browser IndexedDB hardware store securely
                saveTrackToDatabase(systemTrackPayload, () => {
                    libraryTracksList.push(systemTrackPayload);
                    const freshIndex = libraryTracksList.length - 1;

                    build3DTrackDOMCard(systemTrackPayload, freshIndex);

                    if (checkInitialLibraryBootState && freshIndex === 0) {
                        if (tipsCard) tipsCard.style.display = 'none';
                        triggerFocusedTrackReorientation(0, true);
                    } else {
                        compute3DCaseSpaceTransforms();
                    }

                    if (currentlySelectedPlaylistId !== null) renderDetailTracks();

                    // Continue asynchronous generation queue
                    currentFileIndex++;
                    readNextFile();
                });
            };

            dataReader.readAsDataURL(musicFile);
        }

        readNextFile();
    }

    // --- CAROUSEL TOUCH GESTURE INTERCHANGES ---
    if (dropZoneViewport) {
        dropZoneViewport.addEventListener('touchstart', (e) => {
            trackingMotionActive = true;
            initialTouchX = e.touches[0].clientX;
            slidingReferenceDeltaX = initialTouchX;
        }, { passive: true });

        dropZoneViewport.addEventListener('touchmove', (e) => {
            if (!trackingMotionActive || libraryTracksList.length === 0) return;
            const activeLiveTouchX = e.touches[0].clientX;
            const motionVectorDisplacement = activeLiveTouchX - slidingReferenceDeltaX;
            
            if (Math.abs(motionVectorDisplacement) > 35) {
                if (motionVectorDisplacement > 0 && focusedIndex > 0) {
                    triggerFocusedTrackReorientation(focusedIndex - 1, true);
                    trackingMotionActive = false; 
                } else if (motionVectorDisplacement < 0 && focusedIndex < libraryTracksList.length - 1) {
                    triggerFocusedTrackReorientation(focusedIndex + 1, true);
                    trackingMotionActive = false;
                }
                slidingReferenceDeltaX = activeLiveTouchX;
            }
        }, { passive: true });

        window.addEventListener('touchend', () => trackingMotionActive = false);
    }

    if (importBtn) importBtn.addEventListener('click', () => fileInput.click());
    
    if (fileInput) {
        fileInput.addEventListener('change', (e) => {
            if (e.target.files.length > 0) {
                processSelectedFilesInputPackets(e.target.files);
            }
        });
    }

    // --- ENGINE CORE AUDIO HARDWARE CONTROL LISTENERS ---
    if (playBtn && audioEngine) {
        playBtn.addEventListener('click', () => {
            if (libraryTracksList.length === 0) {
                if (fileInput) fileInput.click();
                return;
            }
            if (audioEngine.paused) {
                 audioEngine.play().catch(() => {});
            } else {
                audioEngine.pause();
            }
        });

        audioEngine.addEventListener('play', () => {
            playBtn.innerHTML = '<i class="fa-solid fa-pause"></i>';
        });

        audioEngine.addEventListener('pause', () => {
            playBtn.innerHTML = '<i class="fa-solid fa-play"></i>';
        });

        audioEngine.addEventListener('timeupdate', () => {
            if (audioEngine.duration && progressFill) {
                const runtimeProgressPercentageValue = (audioEngine.currentTime / audioEngine.duration) * 100;
                progressFill.style.width = `${runtimeProgressPercentageValue}%`;
            }
        });

        audioEngine.addEventListener('ended', () => {
            if (focusedIndex < libraryTracksList.length - 1) {
                triggerFocusedTrackReorientation(focusedIndex + 1, true);
            } else {
                playBtn.innerHTML = '<i class="fa-solid fa-play"></i>';
                if (progressFill) progressFill.style.width = '0%';
            }
        });
    }

    window.addEventListener('resize', compute3DCaseSpaceTransforms);

    // Bootstrap database storage engine on app launch
    initDatabaseEngine(() => {
        loadAllDataFromDatabase();
    });
});
